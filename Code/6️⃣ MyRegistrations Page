import { useState, useEffect } from 'react';
import styles from './MyRegistrations.module.css';

export default function MyRegistrations() {
  const [registrations, setRegistrations] = useState([]);

  useEffect(() => {
    const stored = JSON.parse(localStorage.getItem('fdpRegistrations') || '[]');
    setRegistrations(stored);
  }, []);

  const handleCancel = (id) => {
    if (window.confirm('Are you sure you want to cancel this registration?')) {
      const updated = registrations.filter(r => r.id !== id);
      setRegistrations(updated);
      localStorage.setItem('fdpRegistrations', JSON.stringify(updated));
    }
  };

  if (registrations.length === 0) {
    return (
      <div className={styles.container}>
        <div className={styles.empty}>
          <h2>No Registrations Yet</h2>
          <p>You haven't registered for any programs yet.</p>
          <a href="/" className={styles.backLink}>Browse Available Programs</a>
        </div>
      </div>
    );
  }

  return (
    <div className={styles.container}>
      <h1>My Registrations</h1>
      <div className={styles.registrationsList}>
        {registrations.map(reg => (
          <div key={reg.id} className={styles.registrationCard}>
            <div className={styles.programInfo}>
              <h3>{reg.program.title}</h3>
              <p className={styles.instructor}>Instructor: {reg.program.instructor}</p>
              <div className={styles.details}>
                <span>📅 {new Date(reg.program.date).toLocaleDateString()}</span>
                <span>⏰ {reg.program.time}</span>
                <span>📍 {reg.program.location}</span>
              </div>
            </div>
            <div className={styles.participantInfo}>
              <h4>Registration Details</h4>
              <p><strong>Name:</strong> {reg.firstName} {reg.lastName}</p>
              <p><strong>Email:</strong> {reg.email}</p>
              <p><strong>Phone:</strong> {reg.phone}</p>
              <p><strong>Department:</strong> {reg.department}</p>
              <p><strong>Designation:</strong> {reg.designation}</p>
              <p className={styles.registeredAt}>
                Registered on: {new Date(reg.registeredAt).toLocaleDateString()}
              </p>
            </div>
            <button 
              className={styles.cancelBtn}
              onClick={() => handleCancel(reg.id)}
            >
              Cancel Registration
            </button>
          </div>
        ))}
      </div>
    </div>
  );
}
